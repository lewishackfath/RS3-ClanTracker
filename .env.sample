# Clan Tracker - Environment Configuration
# Copy this file to .env and update values for each deployment.

# Database
TRACKER_DB_HOST=localhost
TRACKER_DB_NAME=rs_clan_tracker
TRACKER_DB_USER=rs_clan_tracker_user
TRACKER_DB_PASS=change_me
TRACKER_DB_CHARSET=utf8mb4

# Single-clan deployment
# This is the clan ID from the clans table. The index page opens this clan automatically.
TRACKER_CLAN_ID=1

# Branding
TRACKER_BRAND_NAME=Clan Tracker
TRACKER_BRAND_SHORT_NAME=Clan
TRACKER_BRAND_SUBTITLE=Clan overview & member lookup
TRACKER_BRAND_LOGO_URL=assets/hit-media.png
# Relative path or https URL. Leave as assets/bg.png to use the bundled background.
TRACKER_BRAND_BACKGROUND_URL=assets/bg.png
TRACKER_BRAND_HOME_URL=index
TRACKER_BRAND_DOMAIN=tracker.example.com
TRACKER_BRAND_FOOTER_TITLE=Clan Tracker

# Optional footer/developer branding
TRACKER_DEVELOPER_NAME=HIT Media
TRACKER_DEVELOPER_LOGO_URL=assets/hit-media.png

# Optional nav link
TRACKER_SHOW_BINGO_LINK=false
TRACKER_BRAND_BINGO_URL=https://bingo.example.com


# Optional API cache TTLs for player-page JSON cache tables
# Defaults are 6 hours if omitted.
TRACKER_HISCORES_LITE_TTL_SECONDS=21600
TRACKER_RM_QUESTS_TTL_SECONDS=21600
